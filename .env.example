# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# Notion integration token
# Get it from: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_token_here

# Figma personal access token
# Get it from: Figma → Settings → Security → Personal access tokens
FIGMA_API_KEY=figd_your_token_here

# GitHub personal access token
# Get it from: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Required scopes: repo (read + write), pull_requests (read + write)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Exposed to the browser for the /build (Propose a Change) page
# Uses the same token as above — must have issues:write scope
VITE_GITHUB_TOKEN=ghp_your_token_here
# Format: owner/repo  e.g. acme/peopledesk
VITE_GITHUB_REPO=owner/repo
